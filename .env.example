# ─────────────────────────────────────────────────────────────
#  Copy this file to .env.local for local dev
#  Set these same variables in Vercel dashboard:
#  Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Pusher Server-side keys (from Pusher dashboard → App Keys)
PUSHER_APP_ID=your_app_id_here
PUSHER_KEY=your_key_here
PUSHER_SECRET=your_secret_here
PUSHER_CLUSTER=ap2

# A secret string — NodeMCU must send this in x-device-secret header
# Make it something random e.g. "smartband_2024_xyz"
DEVICE_SECRET=your_device_secret_here